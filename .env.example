# 服务端口
PORT=3000

# JWT 密钥（生产环境请用随机长字符串）
JWT_SECRET=change-me-to-a-random-secret

# PostgreSQL 连接
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_NAME=opc_db

# AI 配置（平台统一 Key）
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=sk-your-api-key
AI_MODEL=qwen3.6-plus
AI_ENABLE_THINKING=false

# SMTP 邮件服务（用于邮箱验证码注册）
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your-email@163.com
SMTP_PASS=your-smtp-authorization-code

# UAPI 搜索引擎密钥（联网搜索能力）
UAPI_KEY=uapi-your-key-here
UAPI_URL=https://uapis.cn/api/v1/search/aggregate

# CORS 允许的前端域名（生产环境请填写实际域名，开发环境可用 *）
CORS_ORIGIN=*

# 高德地图 Web JS API Key（前端地图渲染）
AMAP_KEY=your-amap-web-js-key

# 高德地图 Web 服务 Key（后端地理编码）
AMAP_SERVER_KEY=your-amap-server-key

# 是否开启本地模式（生产环境必须为 false）
LOCAL_MODE=false

# AI 运行模式: local（自配模型） | cloud（套餐代理） | hybrid（混合）
AI_MODE=local

# 桌面本地版 → 云端代理地址（线上版不填）
# OPC_CLOUD_API_URL=https://ai.xhopc.com

# 本地 SQLite 模式专用；线上不用填
# DB_TYPE=sqlite
# SQLITE_PATH=xhopc-local.db

# 微信客服二维码（可选）
WECHAT_SERVICE_QR_URL=

# 管理员初始密码（首次启动时创建）
ADMIN_PHONE=13800000000
ADMIN_PASSWORD=admin123
